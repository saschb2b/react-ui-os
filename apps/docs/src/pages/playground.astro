---
import PlaygroundDesktop from "~/components/playground/PlaygroundDesktop";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Playground — react-ui-os</title>
    <meta
      name="description"
      content="The full multi-window react-ui-os demo. Browse the components, open windows side by side, switch themes from Settings."
    />
    <style>
      html,
      body {
        margin: 0;
        padding: 0;
        height: 100%;
        background: #0a0c1a;
        color: #f1f3f8;
        font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
        color-scheme: dark;
      }
      * {
        box-sizing: border-box;
      }
    </style>
  </head>
  <body>
    <PlaygroundDesktop client:load />
  </body>
</html>
