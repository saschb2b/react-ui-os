---
import Layout from "~/layouts/Layout.astro";
import DocsDesktop from "~/desktop/DocsDesktop";
---

<Layout
  title="react-ui-os — A React desktop in one line"
  description="A React component library that ships a working OS-style desktop in one line. Apps as data, themes as token bags, Settings as a real window, Spotlight as the keyboard front door."
>
  <h1>react-ui-os</h1>
  <p>
    A React component library that ships a working OS-style desktop in one
    line. Drop <code>&lt;Desktop apps={["apps={apps}"]} theme={["theme={theme}"]}
    /&gt;</code> and you get wallpaper, dock, draggable windows, traffic
    lights, Spotlight, and Settings.
  </p>
  <h2>Install</h2>
  <pre>pnpm add @react-ui-os/desktop @react-ui-os/theme-default</pre>
  <h2>One-line API</h2>
  <pre>{`import { Desktop } from "@react-ui-os/desktop";
import { defaultTheme } from "@react-ui-os/theme-default";

<Desktop apps={apps} theme={defaultTheme} />;`}</pre>
  <p>
    This site is itself an instance of react-ui-os. With JavaScript enabled,
    you should see a desktop rendered above this fallback content.
  </p>

  <DocsDesktop client:load />
</Layout>
