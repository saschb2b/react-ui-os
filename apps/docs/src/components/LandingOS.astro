---
/**
 * Landing centerpiece: a large, live desktop with a page-level OS switcher.
 * Clicking macOS / Windows / Ubuntu postMessages the embedded playground, which
 * morphs the whole desktop in place, so the differentiator (one skeleton, three
 * faithful OSes) is something the visitor triggers from the page, not a claim.
 * The iframe reports its current look back so the pills stay in sync with the
 * in-canvas switcher and the visitor's stored choice.
 */
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const src = `${base}playground`;

const oses = [
  { id: "macos", name: "macOS", accent: "#6b8afd" },
  { id: "windows", name: "Windows", accent: "#0078d4" },
  { id: "ubuntu", name: "Ubuntu", accent: "#e95420" },
];
---

<div class="landing-os">
  <div class="landing-os__switch" role="group" aria-label="Switch the desktop's operating system">
    <span class="landing-os__prompt">Switch the OS, live</span>
    {
      oses.map((os, i) => (
        <button
          type="button"
          class="landing-os__pill"
          data-theme={os.id}
          style={`--pill-accent: ${os.accent}`}
          aria-pressed={i === 0 ? "true" : "false"}
        >
          {os.name}
        </button>
      ))
    }
  </div>

  <figure class="landing-os__window">
    <header class="landing-os__bar">
      <span class="landing-os__dots" aria-hidden>
        <span></span><span></span><span></span>
      </span>
      <span class="landing-os__label">react-ui-os, running live</span>
      <a class="landing-os__open" href={src} target="_blank" rel="noreferrer">
        Open full-screen ↗
      </a>
    </header>
    <iframe
      class="landing-os__frame"
      src={src}
      title="react-ui-os live desktop"
      loading="eager"
    ></iframe>
  </figure>

  <p class="landing-os__hint">
    Real, not a screenshot. Drag and resize the windows, press <kbd>Cmd-K</kbd> for
    Spotlight, or flip the OS above and watch the chrome, dock, icons, and motion change.
  </p>
</div>

<style>
  .landing-os {
    margin: 1.25rem 0 2rem;
    width: min(1180px, calc(100vw - 280px));
    margin-left: 50%;
    transform: translateX(-50%);
  }
  @media (max-width: 1100px) {
    .landing-os {
      width: calc(100% + 32px);
      margin-left: -16px;
      transform: none;
    }
  }
  @media (max-width: 600px) {
    .landing-os {
      width: 100%;
      margin-left: 0;
    }
  }

  .landing-os__switch {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.85rem;
  }

  .landing-os__prompt {
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
    margin-right: 0.35rem;
  }

  .landing-os__pill {
    appearance: none;
    cursor: pointer;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--sl-color-gray-1);
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999px;
    padding: 0.4rem 1.05rem;
    transition:
      background 150ms ease,
      border-color 150ms ease,
      color 150ms ease,
      transform 120ms ease;
  }

  .landing-os__pill:hover {
    transform: translateY(-1px);
    border-color: var(--pill-accent);
  }

  .landing-os__pill[aria-pressed="true"] {
    background: var(--pill-accent);
    border-color: var(--pill-accent);
    color: #fff;
  }

  .landing-os__window {
    margin: 0;
    border-radius: 14px;
    border: 1px solid var(--sl-color-gray-5);
    overflow: hidden;
    background: var(--sl-color-black);
    box-shadow: 0 30px 70px -24px rgba(0, 0, 0, 0.65);
    position: relative;
    z-index: 1;
    isolation: isolate;
  }

  .landing-os__bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.8rem;
    background: var(--sl-color-gray-6);
    border-bottom: 1px solid var(--sl-color-gray-5);
    font-size: 0.78rem;
  }

  .landing-os__dots {
    display: inline-flex;
    gap: 5px;
  }
  .landing-os__dots span {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .landing-os__dots span:nth-child(1) {
    background: #ff5f57;
  }
  .landing-os__dots span:nth-child(2) {
    background: #febc2e;
  }
  .landing-os__dots span:nth-child(3) {
    background: #28c840;
  }

  .landing-os__label {
    color: var(--sl-color-gray-3);
    flex: 1;
    text-align: center;
  }

  .landing-os__open {
    color: var(--sl-color-accent);
    text-decoration: none;
    font-size: 0.72rem;
  }
  .landing-os__open:hover {
    text-decoration: underline;
  }

  .landing-os__frame {
    display: block;
    width: 100%;
    height: 660px;
    border: 0;
    background: var(--sl-color-black);
  }
  @media (max-width: 800px) {
    .landing-os__frame {
      height: 460px;
    }
  }

  .landing-os__hint {
    margin: 0.85rem auto 0;
    max-width: 60ch;
    text-align: center;
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
  }
  .landing-os__hint kbd {
    font-size: 0.78em;
  }
</style>

<script>
  const frame = document.querySelector<HTMLIFrameElement>(".landing-os__frame");
  const pills = Array.from(
    document.querySelectorAll<HTMLButtonElement>(".landing-os__pill"),
  );

  for (const pill of pills) {
    pill.addEventListener("click", () => {
      const theme = pill.dataset.theme;
      frame?.contentWindow?.postMessage({ type: "rui:set-theme", theme }, "*");
      for (const p of pills) {
        p.setAttribute("aria-pressed", String(p === pill));
      }
    });
  }

  // Keep the pills in sync with the iframe's actual look (its stored choice on
  // boot, or an in-canvas switch).
  window.addEventListener("message", (event) => {
    const data = event.data as { type?: string; theme?: string } | null;
    if (data?.type !== "rui:theme") return;
    for (const p of pills) {
      p.setAttribute("aria-pressed", String(p.dataset.theme === data.theme));
    }
  });
</script>
