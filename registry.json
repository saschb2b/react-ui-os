      "type": "registry:block",
      "title": "Notes",
      "description": "A two-pane plain-text notes app with persistence. The first line of each note becomes its title.",
      "categories": ["productivity"],
      "dependencies": ["@react-ui-os/core", "@react-ui-os/desktop"],
      "docs": "Register Notes with the desktop: import { notesApp } from \"@/components/os-apps/notes\" and add it to the apps array you pass to <Desktop apps={[...]} />.",
      "meta": { "appId": "notes", "export": "notesApp", "accent": "#f59e0b" },
      "files": [
        {
