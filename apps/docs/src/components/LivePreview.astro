---
/**
 * Embeddable live demo of react-ui-os. Renders an iframe pointing at the
 * dedicated /playground route so the running library can be dropped inline
 * into any docs page. The card chrome (border, radius, header) makes it
 * read clearly as "a contained preview" rather than the page itself.
 *
 * `wide` breaks out of the Starlight content column so the desktop chrome
 * has room to breathe. Defaults are tuned so a normal embed shows the
 * menu bar, a centered window, and the full dock without the bottom edge
 * being clipped by the iframe.
 */
interface Props {
  /**
   * Path or query to append after the playground base URL. Defaults to the
   * catch-all playground. Pass `?demo=spotlight` to deep-link into a feature.
   */
  src?: string;
  /** CSS height. Defaults to 560px. */
  height?: string;
  /** Optional card label shown above the preview. */
  label?: string;
  /**
   * Break out of the Starlight content column. Off by default — the OS
   * chrome is responsible for adapting to whatever space the article
   * column gives it. Pass `wide` only when the demo legitimately needs
   * a wider canvas (e.g. side-by-side window comparisons).
   */
  wide?: boolean;
}

const {
  src = "",
  height = "520px",
  label = "Live preview",
  wide = false,
} = Astro.props;

// Resolve against the deploy's base URL so the iframe works locally, under
// the /react-ui-os/ Pages prefix, and behind a custom domain.
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const resolvedSrc = src.startsWith("?")
  ? `${base}playground${src}`
  : `${base}playground${src ? `/${src.replace(/^\//, "")}` : ""}`;

const figureClass = `rui-live-preview${wide ? " rui-live-preview--wide" : ""}`;
---

<figure class={figureClass}>
  <header class="rui-live-preview__bar">
    <span class="rui-live-preview__dots" aria-hidden>
      <span></span>
      <span></span>
      <span></span>
    </span>
    <span class="rui-live-preview__label">{label}</span>
    <a class="rui-live-preview__open" href={resolvedSrc} target="_blank" rel="noreferrer">
      Open in new tab ↗
    </a>
  </header>
  <iframe
    src={resolvedSrc}
    title={label}
    loading="lazy"
    style={`height: ${height};`}
    class="rui-live-preview__frame"
  ></iframe>
</figure>

<style>
  .rui-live-preview {
    margin: 1.5rem 0;
    border-radius: 12px;
    border: 1px solid var(--sl-color-gray-5);
    overflow: hidden;
    background: var(--sl-color-black);
    box-shadow: 0 16px 40px -12px rgba(0, 0, 0, 0.45);
    /*
     * Promote the figure into its own stacking context. Without this,
     * Starlight's right-side TOC divider (which has its own stacking
     * context further down the tree) paints over the figure when we
     * break out of the content column.
     */
    position: relative;
    z-index: 1;
    isolation: isolate;
  }

  /*
   * Break out of the Starlight content column. Article content tops out
   * around 800 px; widening to ~1100 px gives the desktop chrome room
   * for the dock and menu-bar widgets without crossing into the TOC
   * column (which lives roughly 1180 px+ from page left at this width).
   * The transform-based recenter keeps the article gutter symmetric.
   */
  .rui-live-preview--wide {
    width: min(1100px, calc(100vw - 320px));
    margin-left: 50%;
    transform: translateX(-50%);
  }

  /* At Starlight's TOC breakpoint the right column collapses, so we can
     extend farther without bumping into it. */
  @media (max-width: 1100px) {
    .rui-live-preview--wide {
      width: calc(100% + 32px);
      margin-left: -16px;
      transform: none;
    }
  }

  @media (max-width: 600px) {
    .rui-live-preview--wide {
      width: 100%;
      margin-left: 0;
    }
  }

  .rui-live-preview__bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    background: var(--sl-color-gray-6);
    border-bottom: 1px solid var(--sl-color-gray-5);
    font-size: 0.78rem;
  }

  .rui-live-preview__dots {
    display: inline-flex;
    gap: 4px;
  }

  .rui-live-preview__dots span {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--sl-color-gray-4);
  }

  .rui-live-preview__dots span:nth-child(1) {
    background: #ff5f57;
  }
  .rui-live-preview__dots span:nth-child(2) {
    background: #febc2e;
  }
  .rui-live-preview__dots span:nth-child(3) {
    background: #28c840;
  }

  .rui-live-preview__label {
    color: var(--sl-color-gray-3);
    flex: 1;
    text-align: center;
  }

  .rui-live-preview__open {
    color: var(--sl-color-accent);
    text-decoration: none;
    font-size: 0.72rem;
  }

  .rui-live-preview__open:hover {
    text-decoration: underline;
  }

  .rui-live-preview__frame {
    display: block;
    width: 100%;
    border: 0;
    background: var(--sl-color-black);
  }
</style>
