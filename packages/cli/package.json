{
  "name": "@react-ui-os/cli",
  "version": "0.0.0",
  "private": true,
  "description": "CLI that copies react-ui-os apps from a registry into your codebase, so you own the files.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saschb2b/react-ui-os.git",
    "directory": "packages/cli"
  },
  "homepage": "https://saschb2b.github.io/react-ui-os",
  "license": "MIT",
  "type": "module",
  "bin": {
    "react-ui-os": "./dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build-data.mjs && tsup",
    "typecheck": "node scripts/build-data.mjs && tsc --noEmit",
    "test": "node scripts/build-data.mjs && vitest run",
    "lint": "eslint src tests"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
