---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "react-ui-os",
  description = "A React component library that ships a working OS-style desktop in one line.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style is:global>
      :root {
        color-scheme: dark;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        height: 100%;
        background: #0a0c1a;
        color: #f1f3f8;
        font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
      }
      * {
        box-sizing: border-box;
      }
      /* The desktop island uses position: fixed; inset: 0; so it sits on top
         of the no-JS fallback content underneath. Hide the fallback once the
         island mounts to avoid double-render. */
      body[data-desktop-mounted="true"] .noscript-fallback {
        display: none;
      }
      .noscript-fallback {
        padding: 32px;
        max-width: 760px;
        margin: 0 auto;
        line-height: 1.6;
      }
      .noscript-fallback h1 {
        font-size: 28px;
      }
      .noscript-fallback h2 {
        font-size: 20px;
        margin-top: 32px;
      }
      .noscript-fallback code,
      .noscript-fallback pre {
        background: rgba(255, 255, 255, 0.06);
        border-radius: 4px;
        padding: 1px 4px;
        font-family: "SF Mono", Menlo, monospace;
        font-size: 13px;
      }
      .noscript-fallback pre {
        padding: 12px;
        overflow: auto;
      }
    </style>
  </head>
  <body>
    <main class="noscript-fallback">
      <slot />
    </main>
    <script>
      // Flag the body once any client island has mounted so the no-JS
      // fallback hides cleanly. Astro fires `astro:page-load` after the
      // island hydration sweep.
      document.addEventListener("astro:page-load", () => {
        document.body.dataset.desktopMounted = "true";
      });
    </script>
  </body>
</html>
