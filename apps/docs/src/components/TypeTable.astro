---
/**
 * Renders the fields of a TypeScript interface as a documentation table,
 * sourced from src/data/types.json. The JSON is regenerated by
 * `scripts/extract-types.mjs` (runs as the docs prebuild step) so the
 * tables always reflect the actual source.
 *
 * Usage in mdx:
 *   <TypeTable name="StorageAdapter" />
 *
 * Optional props:
 *   - `hideDescription` — skips the type-level JSDoc paragraph above the
 *     table when the surrounding prose already covers it.
 *   - `omit={['internalField']}` — drops fields by name.
 */
import types from "../data/types.json";

interface Props {
  name: string;
  hideDescription?: boolean;
  omit?: string[];
}

const { name, hideDescription = false, omit = [] } = Astro.props;

const spec = (types as { types: Record<string, TypeSpec> }).types[name];

interface FieldSpec {
  name: string;
  type: string;
  optional: boolean;
  description?: string;
}

interface TypeSpec {
  name: string;
  package: string;
  sourceFile: string;
  kind: "interface" | "alias";
  description?: string;
  fields?: FieldSpec[];
  aliasOf?: string;
}

const omitSet = new Set(omit);
const visibleFields = spec?.fields?.filter((f) => !omitSet.has(f.name)) ?? [];
const repoBlob = "https://github.com/saschb2b/react-ui-os/blob/main";
---

{
  !spec && (
    <div class="rui-type-table__missing">
      <strong>TypeTable:</strong> no entry for <code>{name}</code> in
      <code>types.json</code>. Add it to <code>apps/docs/scripts/extract-types.mjs</code>
      and rerun the extractor.
    </div>
  )
}

{
  spec && (
    <div class="rui-type-table">
      {!hideDescription && spec.description && (
        <p class="rui-type-table__intro">{spec.description}</p>
      )}

      {spec.kind === "alias" && spec.aliasOf && (
        <pre class="rui-type-table__alias"><code>type {spec.name} = {spec.aliasOf}</code></pre>
      )}

      {spec.kind === "interface" && visibleFields.length > 0 && (
        <table class="rui-type-table__grid">
          <thead>
            <tr>
              <th>Field</th>
              <th>Type</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            {visibleFields.map((field) => (
              <tr>
                <td class="rui-type-table__name">
                  <code>{field.name}</code>
                  {field.optional && <span class="rui-type-table__opt">?</span>}
                </td>
                <td class="rui-type-table__type">
                  <code>{field.type}</code>
                </td>
                <td class="rui-type-table__desc">
                  {field.description ?? <span class="rui-type-table__muted">—</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}

      <p class="rui-type-table__footer">
        Generated from{" "}
        <a href={`${repoBlob}/${spec.sourceFile}`} target="_blank" rel="noreferrer">
          <code>{spec.sourceFile}</code>
        </a>{" "}
        in <code>{spec.package}</code>.
      </p>
    </div>
  )
}

<style>
  .rui-type-table {
    margin: 1.25rem 0;
  }

  .rui-type-table__missing {
    border: 1px solid #d97706;
    background: rgba(217, 119, 6, 0.08);
    color: #fbbf24;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-size: 0.85rem;
  }

  .rui-type-table__intro {
    color: var(--sl-color-gray-2);
    margin-top: 0;
  }

  .rui-type-table__alias {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    background: var(--sl-color-black);
    overflow-x: auto;
  }

  .rui-type-table__grid {
    width: 100%;
    border-collapse: collapse;
    table-layout: auto;
    font-size: 0.88rem;
  }

  .rui-type-table__grid th,
  .rui-type-table__grid td {
    text-align: left;
    padding: 0.55rem 0.75rem;
    vertical-align: top;
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  .rui-type-table__grid th {
    color: var(--sl-color-gray-3);
    font-weight: 600;
    background: var(--sl-color-gray-6);
  }

  .rui-type-table__name code {
    white-space: nowrap;
  }

  .rui-type-table__opt {
    color: var(--sl-color-gray-4);
    margin-left: 2px;
  }

  .rui-type-table__type code {
    background: var(--sl-color-black);
    border: 1px solid var(--sl-color-gray-5);
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 0.82rem;
    word-break: break-word;
  }

  .rui-type-table__desc {
    color: var(--sl-color-gray-2);
    white-space: pre-wrap;
  }

  .rui-type-table__muted {
    color: var(--sl-color-gray-4);
  }

  .rui-type-table__footer {
    font-size: 0.78rem;
    color: var(--sl-color-gray-4);
    margin-top: 0.75rem;
  }

  .rui-type-table__footer a {
    color: var(--sl-color-accent);
    text-decoration: none;
  }

  .rui-type-table__footer a:hover {
    text-decoration: underline;
  }
</style>
