---
/**
 * Landing hero (overrides Starlight's default Hero on the splash page).
 * Modeled on the Apple OS product pages: a centered stack of eyebrow, a
 * giant headline, one gray subhead, and a pill CTA row, with the product
 * shot full-width underneath. Ours is better than a screenshot: the live
 * desktop, cycling macOS / Windows / Ubuntu, with the OS switcher built
 * into the window's title bar. Clicking a segment or hovering the window
 * pins the current look.
 */
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const src = `${base}playground?embed=1`;

const oses = [
  { id: "macos", name: "macOS", accent: "#6b8afd" },
  { id: "windows", name: "Windows", accent: "#0078d4" },
  { id: "ubuntu", name: "Ubuntu", accent: "#e95420" },
];
---

<section class="lh">
  <p class="lh__eyebrow">react-ui-os</p>
  <h1 class="lh__title">A real desktop OS,<br /> in one React component.</h1>
  <p class="lh__tagline">
    macOS, Windows, and Ubuntu, cloned down to the chrome. Fill it with your apps and
    ship it to the browser.
  </p>
  <div class="lh__actions">
    <a class="lh__cta" href={`${base}quickstart/`}>Get started</a>
    <a class="lh__alt" href={`${base}playground`} target="_blank" rel="noreferrer"
      >Open the playground ↗</a
    >
  </div>

  <figure class="lh__window">
    <header class="lh__bar">
      <span class="lh__dots" aria-hidden><span></span><span></span><span></span></span>
      <div class="lh__segs" role="group" aria-label="Switch the operating system">
        {
          oses.map((os, i) => (
            <button
              type="button"
              class="lh__seg"
              data-theme={os.id}
              style={`--seg-accent: ${os.accent}`}
              aria-pressed={i === 0 ? "true" : "false"}
            >
              {os.name}
            </button>
          ))
        }
      </div>
      <a class="lh__open" href={`${base}playground`} target="_blank" rel="noreferrer">
        Full-screen ↗
      </a>
    </header>
    <iframe class="lh__frame" src={src} title="react-ui-os live desktop" loading="eager"
    ></iframe>
  </figure>
  <p class="lh__below">
    This is the library running live, not a video. Drag a window, press Cmd-K, switch
    the OS.
  </p>
</section>

<style>
  .lh {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: min(1480px, calc(100vw - 48px));
    margin: 1.5rem 50% 1rem;
    transform: translateX(-50%);
  }
  @media (max-width: 920px) {
    .lh {
      width: 100%;
      margin-left: 0;
      transform: none;
    }
  }

  .lh__eyebrow {
    margin: 0 0 0.75rem;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--sl-color-accent);
  }
  .lh__title {
    margin: 0 0 1.1rem;
    font-size: clamp(2.6rem, 1.6rem + 4.6vw, 5rem);
    line-height: 1.04;
    letter-spacing: -0.03em;
    font-weight: 700;
  }
  .lh__tagline {
    margin: 0 0 1.6rem;
    font-size: clamp(1.05rem, 0.95rem + 0.5vw, 1.35rem);
    line-height: 1.5;
    color: var(--sl-color-gray-2);
    max-width: 52ch;
  }

  .lh__actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }
  .lh__cta {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.75rem 1.7rem;
    font-size: 1.02rem;
    font-weight: 600;
    text-decoration: none;
    background: var(--sl-color-accent);
    color: var(--sl-color-black);
  }
  .lh__cta:hover {
    background: var(--sl-color-accent-high);
  }
  .lh__alt {
    font-size: 1.02rem;
    font-weight: 500;
    color: var(--sl-color-accent);
    text-decoration: none;
  }
  .lh__alt:hover {
    text-decoration: underline;
  }

  /* The live desktop, the product shot. */
  .lh__window {
    margin: 0;
    width: 100%;
    border-radius: 18px;
    border: 1px solid var(--sl-color-gray-5);
    overflow: hidden;
    background: var(--sl-color-black);
    box-shadow: 0 60px 120px -40px rgba(0, 0, 0, 0.8);
    isolation: isolate;
  }
  .lh__bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 44px;
    padding: 0 0.95rem;
    background: var(--sl-color-gray-6);
    border-bottom: 1px solid var(--sl-color-gray-5);
  }
  .lh__dots {
    display: inline-flex;
    gap: 6px;
    flex: none;
  }
  .lh__dots span {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .lh__dots span:nth-child(1) {
    background: #ff5f57;
  }
  .lh__dots span:nth-child(2) {
    background: #febc2e;
  }
  .lh__dots span:nth-child(3) {
    background: #28c840;
  }

  /* Segmented OS switcher, built into the title bar. */
  .lh__segs {
    display: inline-flex;
    gap: 2px;
    margin: 0 auto;
    padding: 3px;
    background: rgba(0, 0, 0, 0.28);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999px;
  }
  .lh__seg {
    appearance: none;
    border: 0;
    cursor: pointer;
    font: inherit;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--sl-color-gray-2);
    background: transparent;
    border-radius: 999px;
    padding: 0.3rem 0.9rem;
    transition:
      background 150ms ease,
      color 150ms ease;
  }
  .lh__seg:hover:not([aria-pressed="true"]) {
    color: var(--sl-color-white);
  }
  .lh__seg[aria-pressed="true"] {
    background: var(--seg-accent);
    color: #fff;
  }

  .lh__open {
    flex: none;
    color: var(--sl-color-gray-3);
    text-decoration: none;
    font-size: 0.72rem;
  }
  .lh__open:hover {
    color: var(--sl-color-accent);
  }
  @media (max-width: 620px) {
    .lh__open {
      display: none;
    }
  }

  .lh__frame {
    display: block;
    width: 100%;
    height: clamp(440px, 58vw, 720px);
    border: 0;
    background: var(--sl-color-black);
  }

  .lh__below {
    margin: 1rem 0 0;
    font-size: 0.88rem;
    color: var(--sl-color-gray-3);
  }
</style>

<script>
  const frame = document.querySelector<HTMLIFrameElement>(".lh__frame");
  const segs = Array.from(document.querySelectorAll<HTMLButtonElement>(".lh__seg"));
  const order = ["macos", "windows", "ubuntu"];

  let cycling = true;
  let timer: ReturnType<typeof setInterval> | undefined;
  let started = false;

  function applySegs(theme: string | undefined) {
    for (const s of segs) {
      s.setAttribute("aria-pressed", String(s.dataset.theme === theme));
    }
  }
  function setOS(theme: string) {
    frame?.contentWindow?.postMessage({ type: "rui:set-theme", theme }, "*");
    applySegs(theme);
  }
  function stopCycle() {
    cycling = false;
    if (timer) clearInterval(timer);
  }

  // Begin the auto-cycle once the embedded desktop reports it is ready (it posts
  // its current theme on mount); keep the segments synced to what it shows.
  window.addEventListener("message", (event) => {
    const data = event.data as { type?: string; theme?: string } | null;
    if (data?.type !== "rui:theme") return;
    applySegs(data.theme);
    if (started) return;
    started = true;
    let idx = Math.max(0, order.indexOf(data.theme ?? "macos"));
    timer = setInterval(() => {
      if (!cycling) return;
      idx = (idx + 1) % order.length;
      setOS(order[idx]!);
    }, 3800);
  });

  for (const seg of segs) {
    seg.addEventListener("click", () => {
      stopCycle();
      setOS(seg.dataset.theme ?? "macos");
    });
  }
  // Engaging the desktop pins the look so it never switches mid-interaction.
  document.querySelector(".lh__window")?.addEventListener("pointerenter", stopCycle);
</script>
