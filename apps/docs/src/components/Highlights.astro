---
/**
 * The Apple-style highlights carousel: a horizontally scrolling row of large
 * rounded screenshot cards with bold-lead captions and round prev/next
 * buttons. Scroll-snap does the work; the buttons are a convenience.
 */
import { Image } from "astro:assets";
import heroShot from "../assets/hero.png";
import spotlightShot from "../assets/spotlight.png";
import settingsShot from "../assets/settings.png";
import notificationsShot from "../assets/notifications.png";

const cards = [
  {
    img: heroShot,
    alt: "A macOS-style desktop with an open window, dock, and menu bar",
    lead: "A window manager, for real.",
    text: "Drag at 60 fps, resize from any edge, snap to halves and quarters, minimize with the genie. Window state lives in React; your routes can watch it.",
  },
  {
    img: spotlightShot,
    alt: "The Spotlight palette listing apps and system windows",
    lead: "Spotlight, on Cmd-K.",
    text: "Apps, system windows, settings, and any source you register, searchable from one palette. The Windows theme presents it as Start, Ubuntu as the app grid.",
  },
  {
    img: settingsShot,
    alt: "The Settings window with accent, parallax, and radius controls",
    lead: "Settings, on Cmd-,.",
    text: "A theme declares which tokens end users may tweak; the panel renders itself and preferences persist through the storage adapter. No code on your side.",
  },
  {
    img: notificationsShot,
    alt: "A notification toast stack in the top-right corner of the desktop",
    lead: "One notify() call, four surfaces.",
    text: "A toast stack, per-app dock badges, a menu-bar dot, and the Notification Center, wired from a single imperative call in core.",
  },
];
---

<section class="hl" id="highlights">
  <header class="hl__head">
    <p class="hl__eyebrow">Highlights</p>
    <h2 class="hl__title">Have a look around.</h2>
    <p class="hl__sub">
      Everything below is rendered by the library. The desktop above is the same code,
      running live.
    </p>
  </header>

  <div class="hl__track" tabindex="0" aria-label="Highlight cards">
    {
      cards.map((card) => (
        <figure class="hl__card">
          <Image
            src={card.img}
            alt={card.alt}
            widths={[800, 1400]}
            sizes="(max-width: 700px) 86vw, 880px"
            quality={80}
            loading="lazy"
          />
          <figcaption>
            <strong>{card.lead}</strong> {card.text}
          </figcaption>
        </figure>
      ))
    }
  </div>

  <div class="hl__controls">
    <button type="button" class="hl__btn" data-dir="-1" aria-label="Previous highlight">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path
          d="M10 3 5 8l5 5"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </button>
    <button type="button" class="hl__btn" data-dir="1" aria-label="Next highlight">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path
          d="m6 3 5 5-5 5"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </button>
  </div>
</section>

<style>
  .hl {
    width: min(1240px, calc(100vw - 48px));
    margin: 5.5rem 50% 0;
    transform: translateX(-50%);
  }
  @media (max-width: 920px) {
    .hl {
      width: 100%;
      margin-left: 0;
      transform: none;
    }
  }

  .hl__head {
    max-width: 56rem;
    margin-bottom: 2.25rem;
  }
  .hl__eyebrow {
    margin: 0 0 0.65rem;
    font-size: 1.02rem;
    font-weight: 650;
    color: var(--sl-color-accent);
  }
  .hl__title {
    margin: 0;
    font-size: clamp(2rem, 1.2rem + 3.2vw, 3.5rem);
    line-height: 1.07;
    letter-spacing: -0.025em;
    font-weight: 700;
    color: var(--sl-color-white);
  }
  .hl__sub {
    margin: 1.1rem 0 0;
    font-size: clamp(1.02rem, 0.95rem + 0.4vw, 1.25rem);
    line-height: 1.55;
    color: var(--sl-color-gray-2);
    max-width: 58ch;
  }

  /* The card rail. Bleeds to the viewport edge on the right so a peeking
     card invites the scroll, the way the Apple carousels do. */
  .hl__track {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    padding: 0.25rem 0.25rem 0.5rem;
    margin-right: calc(50% - 50vw);
    padding-right: max(calc(50vw - 50% - 24px), 0.25rem);
  }
  .hl__track::-webkit-scrollbar {
    display: none;
  }

  .hl__card {
    flex: none;
    width: min(880px, 86vw);
    margin: 0;
    scroll-snap-align: start;
    border-radius: 24px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-6);
    overflow: hidden;
  }
  .hl__card :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }
  .hl__card figcaption {
    padding: 1.1rem 1.35rem 1.25rem;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--sl-color-gray-2);
  }
  .hl__card figcaption strong {
    color: var(--sl-color-white);
  }

  .hl__controls {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 0.6rem;
    margin-top: 1rem;
  }
  .hl__btn {
    flex: none;
    width: 38px;
    height: 38px;
    padding: 0;
    border-radius: 50%;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-1);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .hl__btn:hover {
    border-color: var(--sl-color-gray-4);
    color: var(--sl-color-white);
  }
</style>

<script>
  const track = document.querySelector<HTMLElement>(".hl__track");
  for (const btn of document.querySelectorAll<HTMLButtonElement>(".hl__btn")) {
    btn.addEventListener("click", () => {
      const card = track?.querySelector<HTMLElement>(".hl__card");
      if (!track || !card) return;
      const step = card.offsetWidth + 20;
      track.scrollBy({ left: step * Number(btn.dataset.dir), behavior: "smooth" });
    });
  }
</script>
