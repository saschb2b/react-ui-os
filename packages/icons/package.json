{
  "name": "@react-ui-os/icons",
  "version": "0.0.0",
  "private": true,
  "description": "License-vetted app icon components for react-ui-os, in line and Fluent styles.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saschb2b/react-ui-os.git",
    "directory": "packages/icons"
  },
  "homepage": "https://saschb2b.github.io/react-ui-os",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^6.0.0"
  }
}
