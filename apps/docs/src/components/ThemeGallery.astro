---
/**
 * Theme gallery for the landing page. One card per reference theme, each a
 * deep link that opens the playground full-screen in that look. The live
 * demo above already carries the in-canvas switcher; these cards name the
 * structural stance each theme exercises so the "same skeleton, different
 * dress" point lands, and give a visitor a direct way to open any single
 * look on its own.
 *
 * The swatch color is each theme's real default accent, sourced from the
 * theme package, so it reads as the theme's signature rather than decoration.
 */
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const themes = [
  {
    id: "default",
    name: "macOS",
    accent: "#6b8afd",
    stance: "Traffic lights, a floating dock, a translucent menu bar.",
  },
  {
    id: "windows",
    name: "Windows",
    accent: "#0078d4",
    stance: "Caption buttons, a flush taskbar, a Start launcher.",
  },
  {
    id: "ubuntu",
    name: "Ubuntu",
    accent: "#e95420",
    stance: "Yaru dark, a left dock, a centered clock, Quick Settings.",
  },
];
---

<div class="theme-gallery">
  {
    themes.map((theme) => (
      <a
        class="theme-gallery__card"
        href={`${base}playground?theme=${theme.id}`}
        target="_blank"
        rel="noreferrer"
      >
        <span class="theme-gallery__head">
          <span
            class="theme-gallery__swatch"
            style={`--swatch: ${theme.accent}`}
            aria-hidden="true"
          />
          <span class="theme-gallery__name">{theme.name}</span>
        </span>
        <span class="theme-gallery__stance">{theme.stance}</span>
        <span class="theme-gallery__open">Open full-screen ↗</span>
      </a>
    ))
  }
</div>

<style>
  .theme-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 0.75rem;
    margin: 1.5rem 0;
  }

  .theme-gallery__card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.95rem 1.05rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 12px;
    background: var(--sl-color-gray-6);
    text-decoration: none;
    color: var(--sl-color-white);
    transition:
      border-color 150ms ease,
      transform 150ms ease;
  }

  .theme-gallery__card:hover {
    border-color: var(--sl-color-accent);
    transform: translateY(-2px);
  }

  .theme-gallery__head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .theme-gallery__swatch {
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: var(--swatch);
    flex: none;
  }

  .theme-gallery__name {
    font-weight: 600;
    font-size: 1rem;
  }

  .theme-gallery__stance {
    font-size: 0.82rem;
    line-height: 1.45;
    color: var(--sl-color-gray-3);
    flex: 1;
  }

  .theme-gallery__open {
    font-size: 0.74rem;
    color: var(--sl-color-accent);
  }
</style>
