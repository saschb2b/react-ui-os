{
  "name": "@react-ui-os/theme-ubuntu",
  "version": "0.0.0",
  "private": true,
  "description": "Ubuntu/GNOME theme for react-ui-os: top bar with centered clock, left dock, Yaru colors and GNOME motion.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saschb2b/react-ui-os.git",
    "directory": "packages/theme-ubuntu"
  },
  "homepage": "https://saschb2b.github.io/react-ui-os",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@react-ui-os/core": "workspace:*"
  },
  "devDependencies": {
    "@react-ui-os/core": "workspace:*",
    "typescript": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
