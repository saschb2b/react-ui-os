---
/**
 * The closing full-bleed call-to-action band, the Microsoft product-page
 * pattern: one big line, the install command, two actions. The surface stays
 * a neutral elevated band (DESIGN.md reserves accent for small affordances).
 */
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<section class="cb" id="install">
  <div class="cb__inner">
    <h2 class="cb__title">Ready when you are.</h2>
    <p class="cb__sub">One install, one tag, a working desktop.</p>
    <code class="cb__cmd">npm install @react-ui-os/desktop @react-ui-os/theme-macos</code>
    <div class="cb__actions">
      <a class="cb__cta" href={`${base}quickstart/`}>Get started</a>
      <a class="cb__link" href={`${base}introduction/`}>Read the docs →</a>
    </div>
  </div>
</section>

<style>
  .cb {
    width: 100vw;
    margin: 6rem 50% 0;
    transform: translateX(-50%);
    background: var(--sl-color-gray-6);
    border-top: 1px solid var(--sl-color-gray-5);
    border-bottom: 1px solid var(--sl-color-gray-5);
  }
  .cb__inner {
    width: min(1240px, calc(100vw - 48px));
    margin: 0 auto;
    padding: 4.5rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .cb__title {
    margin: 0;
    font-size: clamp(2rem, 1.3rem + 2.8vw, 3.2rem);
    line-height: 1.07;
    letter-spacing: -0.025em;
    font-weight: 700;
    color: var(--sl-color-white);
  }
  .cb__sub {
    margin: 0.9rem 0 1.6rem;
    font-size: 1.1rem;
    color: var(--sl-color-gray-2);
  }
  .cb__cmd {
    display: inline-block;
    padding: 0.7rem 1.2rem;
    border-radius: 10px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-black);
    color: var(--sl-color-gray-1);
    font-size: 0.92rem;
    margin-bottom: 1.8rem;
    overflow-x: auto;
    max-width: 100%;
  }
  .cb__actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .cb__cta {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.7rem 1.6rem;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    background: var(--sl-color-accent);
    color: var(--sl-color-black);
  }
  .cb__cta:hover {
    background: var(--sl-color-accent-high);
  }
  .cb__link {
    font-size: 1rem;
    font-weight: 500;
    color: var(--sl-color-accent);
    text-decoration: none;
  }
  .cb__link:hover {
    text-decoration: underline;
  }
</style>
